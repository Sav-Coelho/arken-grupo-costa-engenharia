// Schema inicial — vazio de propósito.
// Adicione models conforme os módulos forem definidos com o cliente.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Placeholder para o Prisma não reclamar de schema sem models.
// Pode ser deletado assim que o primeiro model real for criado.
model _Health {
  id        Int      @id @default(autoincrement())
  checkedAt DateTime @default(now())
}
