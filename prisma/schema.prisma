// Schema do Arken — Grupo Costa Engenharia
// Módulo 1: Gestão de Pessoal por Obra

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Obra ativa (vinda da planilha "Obras Ativas ECF")
model Project {
  id             Int             @id @default(autoincrement())
  code           String          @unique          // ex: "5013"
  name           String                           // ex: "02.201.0097 - BUTANTAN - SPCI E SPDA"
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  aliases        ProjectAlias[]
  allocations    Allocation[]
  snapshotCells  SnapshotCell[]
}

// Mapeamento de nomes curtos usados na planilha de pessoal
// (ex: "BUTANTAN - SPCI" → projeto 5013)
model ProjectAlias {
  id        Int     @id @default(autoincrement())
  alias     String  @unique
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Colaborador (extraído da coluna A da planilha de pessoal)
model Worker {
  id             Int                  @id @default(autoincrement())
  name           String               @unique
  role           String?                                // função/cargo (coluna B; pode mudar entre meses)
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  allocations    Allocation[]
  snapshotCells  SnapshotCell[]
  compensation   WorkerCompensation?
}

// Salário e benefícios do colaborador (vinda da planilha "Colaboradores Valores")
// Usado pra calcular o custo de pessoal por dia × obra.
model WorkerCompensation {
  id                Int      @id @default(autoincrement())
  workerId          Int      @unique
  worker            Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  contractType      String                            // 'CELETISTA' | 'CONTRATO_PF' | 'PJ' | outro
  monthlySalary     Float                             // R$ mensal
  dailyBenefit      Float    @default(0)              // R$ por dia (já vem diário do XLSX)
  benefitPaymentForm String?                          // ex: "CRÉDITO EM CONTA", "RECARGA SWILE"
  updatedAt         DateTime @updatedAt
}

// 1 registro por colaborador × dia
// status PRESENT → projectId obrigatório (alocado na obra)
// status WEEKEND/DAY_OFF/ABSENCE_JUSTIFIED/ABSENCE_UNJUSTIFIED/TERMINATED → projectId null
model Allocation {
  id        Int      @id @default(autoincrement())
  workerId  Int
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  year      Int
  month     Int                              // 1-12
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])
  status    String                           // PRESENT | WEEKEND | DAY_OFF | ABSENCE_JUSTIFIED | ABSENCE_UNJUSTIFIED | TERMINATED
  rawValue  String?                          // valor original da célula (auditoria)
  createdAt DateTime @default(now())

  @@unique([workerId, date])
  @@index([year, month])
  @@index([date])
  @@index([projectId, date])
}

// SnapshotBatch — "foto" intermediária do estado da obra em um dia
// (ex: vistoria das 9h). Cada upload de snapshot gera um SnapshotBatch
// + N SnapshotCells (um por colaborador). Não substitui Allocation;
// convive em paralelo. Histórico permanente.
model SnapshotBatch {
  id          Int            @id @default(autoincrement())
  capturedAt  DateTime       @default(now())   // timestamp do upload
  label       String?                          // ex: "9h", "Vistoria sócios", "12h"
  date        DateTime       @db.Date          // dia referente
  year        Int
  month       Int                              // 1-12
  day         Int                              // 1-31
  cells       SnapshotCell[]

  @@index([year, month, day])
  @@index([date])
}

model SnapshotCell {
  id         Int           @id @default(autoincrement())
  batchId    Int
  batch      SnapshotBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  workerId   Int
  worker     Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  projectId  Int?
  project    Project?      @relation(fields: [projectId], references: [id])
  status     String                            // mesmo enum de Allocation
  rawValue   String?

  @@unique([batchId, workerId])
  @@index([workerId])
}
